sales_month <- data %>% group_by(Year, Month) %>% summarise(total_sales = sum(Sales))
ggplot(sales_month, aes(x = Month, y = total_sales, colour = as.factor(Year))) + geom_line() + labs(title = "Vendas por mẽs")
